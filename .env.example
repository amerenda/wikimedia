# On Mac Mini with compose.yaml: use the hostname `postgres` on mac-mini-shared.
DATABASE_URL=postgresql://wikimedia:YOUR_PASSWORD_HERE@postgres:5432/wikimedia

# From your dev machine (Postgres published on the Mini): replace host and password.
# DATABASE_URL=postgresql://wikimedia:YOUR_PASSWORD_HERE@mac-mini.lan:5432/wikimedia

WIKI_SITE_NAME=Homelab Wiki
